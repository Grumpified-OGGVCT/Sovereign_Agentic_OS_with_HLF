--- a/agents/core/main.py
+++ b/agents/core/main.py
@@ -2,6 +2,12 @@
 Agent executor entrypoint.
 Initialises OpenLLMetry TracerProvider, registers SIGUSR1 handler,
 connects to Dapr pub/sub, and processes Redis Stream intents.
+
