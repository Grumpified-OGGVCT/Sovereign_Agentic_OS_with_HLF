{
  "gateway": {
    "bind": "loopback",
    "auth": {
      "mode": "token"
    }
  },
  "tools": {
    "deny": ["group:automation", "group:runtime", "group:fs"],
    "exec": {
      "security": "deny",
      "ask": "always"
    },
    "elevated": {
      "enabled": false
    }
  },
  "sandbox": {
    "mode": "all",
    "scope": "agent",
    "workspaceAccess": "ro"
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "${OLLAMA_HOST:-http://localhost:11434}"
      }
    }
  }
}
