DEPLOYMENT_TIER=hearth
BASE_DIR=/app
# ── Primary Ollama (local, no auth needed) ──
OLLAMA_HOST=http://localhost:11434
# ── Secondary Ollama (Docker, authenticated, doubles cloud quota) ──
OLLAMA_HOST_SECONDARY=http://localhost:11435
OLLAMA_API_KEY_SECONDARY=<your-secondary-ollama-api-key>
# ── Load-sharing strategy: round_robin | failover | primary_only ──
OLLAMA_LOAD_STRATEGY=failover
PRIMARY_MODEL=<your-primary-model>
REASONING_MODEL=<your-reasoning-model>
SUMMARIZATION_MODEL=<your-summarization-model>
EMBEDDING_MODEL=<your-embedding-model>
OLLAMA_NOAGENT=1
OLLAMA_ALLOWED_MODELS=<comma-separated-allowed-models>
REDIS_URL=redis://redis-broker:6379/0
MAX_GAS_LIMIT=10
MAX_CONTEXT_TOKENS=8192
WEBSEARCH_RATELIMIT_CAPACITY=10
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
